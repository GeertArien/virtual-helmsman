# Copy to .env and fill in your keys:  cp .env.example .env
#
# .env is gitignored and loaded automatically at startup (python-dotenv).
# The app never stores keys in config.yaml -- config only references the
# env-var NAME (llm.api_key_env, llm.qdrant_api_key_env, review.* / documents.*
# qdrant_api_key_env, langfuse_*_key_env). Real environment variables already
# set in your shell take precedence over values in this file.
#
# Leave a key blank to send no credential for that service (fine for an
# unauthenticated local setup).

# --- LM Studio / OpenAI-compatible LLM -------------------------------------
# The LM Studio /v1 API key for the helmsman LLM calls and (langgraph backend
# + local ingestion) the bge-m3 embedding calls. Local LM Studio usually needs
# no key -- leave blank.
LLM_API_KEY=

# --- Qdrant ----------------------------------------------------------------
# Used by the Documents page (/api/documents proxy), the langgraph LLM
# backend's RAG retrieval (llm.qdrant_url), and the local HITL ingestion
# pipeline (review.qdrant_url). Sent as the `api-key` header when set.
QDRANT_API_KEY=

# --- Langfuse (optional) ---------------------------------------------------
# Tracing for the in-backend helmsman (llm.langfuse_enabled) and the ingestion
# doc-summary call (review.langfuse_enabled). Leave blank to run untraced --
# tracing failures never affect the pipeline. Self-hosted? Set the host via
# llm.langfuse_host / review.langfuse_host (blank = Langfuse Cloud).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- optional overrides (applied over config.yaml) -------------------------
# Override the LLM base URL without editing config.yaml.
# LLM_BASE_URL=http://localhost:1234/v1
# Override the simulator backend (mock | real).
# SIMULATOR_BACKEND=mock
