# Copy to .env and fill in your keys:  cp .env.example .env
#
# .env is gitignored and loaded automatically at startup (python-dotenv).
# The app never stores keys in config.yaml -- config only references the
# env-var NAME (llm.api_key_env, documents.qdrant_api_key_env,
# llm.n8n_api_key_env / review.n8n_api_key_env). Real environment variables
# already set in your shell take precedence over values in this file.
#
# Leave a key blank to send no credential for that service (fine for an
# unauthenticated local setup).

# --- LM Studio / OpenAI-compatible LLM -------------------------------------
# Used ONLY when llm.backend = openai_compatible (the agent calls LM Studio's
# /v1 directly). With the default llm.backend = n8n, LM Studio credentials
# live inside n8n, not here -- so you can leave this blank in the n8n setup.
LLM_API_KEY=

# --- Qdrant ----------------------------------------------------------------
# Used by the Documents page (the /api/documents -> qdrant proxy) AND by the
# langgraph LLM backend's RAG retrieval (llm.qdrant_url). Sent as the `api-key`
# header when set.
QDRANT_API_KEY=

# --- Langfuse (optional, llm.backend = langgraph) --------------------------
# Tracing for the in-backend LangGraph helmsman. Only used when
# llm.langfuse_enabled = true. Leave blank to run untraced -- tracing failures
# never affect the pipeline. Override the host via llm.langfuse_host (defaults
# to Langfuse Cloud).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- n8n -------------------------------------------------------------------
# One key for every n8n webhook this app calls: the helmsman LLM webhook and
# the review/audit webhooks. Sent as a custom Header-Auth header whose NAME is
# set in config.yaml (llm.n8n_auth_header / review.n8n_auth_header, default
# X-N8N-API-KEY). Set the name to match your n8n "Header Auth" credential.
N8N_API_KEY=

# --- optional overrides (applied over config.yaml) -------------------------
# Override the LLM base URL without editing config.yaml.
# LLM_BASE_URL=http://localhost:5678
# Override the simulator backend (mock | real).
# SIMULATOR_BACKEND=mock
